# server/.env.example — Backend POC Cooprinsem POS
# Copiar a server/.env antes de ejecutar el backend

# URL de conexion a PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD

# Opcion 1: Servidor Linux Jose Antonio (requiere VPN activa)
# DATABASE_URL="postgresql://postgres:postgres@172.16.33.47:5432/postgres"

# Opcion 2: Supabase (para desarrollo sin VPN)
# DATABASE_URL="postgresql://postgres:PASSWORD@db.xxxx.supabase.co:5432/postgres"

# Opcion 3: PostgreSQL local (desarrollo sin VPN ni Supabase)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cooprinsem_poc"

# Puerto del servidor Express
PORT=3001